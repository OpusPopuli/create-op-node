{
  "name": "create-op-node",
  "version": "0.15.2",
  "description": "Interactive bootstrap for an Opus Populi node — Cloudflare infrastructure, Mac Studio, ghcr.io image pull. From sealed box to public API in one command.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "create-op-node": "./dist/cli.js"
  },
  "exports": "./dist/cli.js",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:sonar": "eslint . --config eslint.sonar.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm lint:sonar && pnpm test && pnpm build"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@clack/prompts": "^0.9.0",
    "@octokit/rest": "^22.0.0",
    "cloudflare": "^4.0.0",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "libsodium-wrappers": "^0.8.4",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.6",
    "eslint": "^9.18.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "opuspopuli",
    "civic-tech",
    "federation",
    "cli",
    "bootstrap",
    "mac-studio",
    "cloudflare-tunnel"
  ],
  "author": "OpusPopuli",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpusPopuli/create-op-node.git"
  },
  "homepage": "https://github.com/OpusPopuli/create-op-node#readme",
  "bugs": "https://github.com/OpusPopuli/create-op-node/issues",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
